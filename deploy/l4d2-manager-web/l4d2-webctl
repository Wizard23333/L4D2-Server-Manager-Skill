#!/usr/bin/env python3
import json
import os
import re
import shutil
import struct
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path


ROOMS = {
    "room1": Path("/opt/l4d2/start_l4d2.sh"),
    "room2": Path("/opt/l4d2/start_l4d2_2.sh"),
}
MAPS_DIR = Path("/opt/l4d2/left4dead2/maps")
GAME_DIR = Path("/opt/l4d2/left4dead2")
ADDONS_DIR = GAME_DIR / "addons"
DISABLED_ADDONS_DIR = GAME_DIR / "addons_disabled"
DOWNLOAD_DIR = Path("/tmp/l4d2-manager-web-downloads")
VPK_EXTRACTOR = Path("/opt/l4d2-manager-web/vpk_extract.py")
MAP_RE = re.compile(r"^[A-Za-z0-9_][A-Za-z0-9_.-]{0,95}$")
WORKSHOP_ID_RE = re.compile(r"^[0-9]{4,20}$")
GAMEMAPS_ID_RE = re.compile(r"^[0-9]{1,12}$")
ADDON_RE = re.compile(r"^[A-Za-z0-9_. -]{1,180}\.vpk$")
GAMEMAPS_HOSTS = {"www.gamemaps.com", "gamemaps.com"}
ALLOWED_EXTRACT_ROOTS = {"maps", "missions", "materials", "models", "sound", "scripts"}
INLINE_ARCHIVE = 0x7FFF


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)


def emit(event, **fields):
    payload = {"event": event}
    payload.update(fields)
    print(json.dumps(payload, ensure_ascii=False), flush=True)


def read_null_string(handle):
    data = []
    while True:
        char = handle.read(1)
        if not char or char == b"\x00":
            break
        data.append(char)
    return b"".join(data).decode("utf-8", errors="ignore")


def vpk_maps(vpk_path):
    maps = set()
    try:
        with open(vpk_path, "rb") as handle:
            header = handle.read(8)
            if len(header) != 8:
                return maps
            signature, version = struct.unpack("<II", header)
            if signature != 0x55AA1234:
                return maps
            tree_size_data = handle.read(4)
            if len(tree_size_data) != 4:
                return maps
            if version == 2:
                handle.read(16)
            header_size = 12 if version == 1 else 28
            handle.seek(header_size)
            while True:
                extension = read_null_string(handle)
                if not extension:
                    break
                while True:
                    path = read_null_string(handle)
                    if not path:
                        break
                    while True:
                        filename = read_null_string(handle)
                        if not filename:
                            break
                        entry_data = handle.read(18)
                        if len(entry_data) != 18:
                            return maps
                        _crc, preload_bytes, _archive_index, _entry_offset, _entry_size, _term = struct.unpack("<IHHIIH", entry_data)
                        handle.read(preload_bytes)
                        if extension.lower() == "bsp" and path.lower() == "maps":
                            maps.add(filename.lower().replace(" ", "_"))
    except OSError:
        return set()
    return maps


def vpk_entries(vpk_path):
    entries = []
    try:
        with open(vpk_path, "rb") as handle:
            header = handle.read(8)
            if len(header) != 8:
                return entries
            signature, version = struct.unpack("<II", header)
            if signature != 0x55AA1234:
                return entries
            tree_size_data = handle.read(4)
            if len(tree_size_data) != 4:
                return entries
            if version == 2:
                handle.read(16)
            header_size = 12 if version == 1 else 28
            handle.seek(header_size)
            while True:
                extension = read_null_string(handle)
                if not extension:
                    break
                while True:
                    path = read_null_string(handle)
                    if not path:
                        break
                    while True:
                        filename = read_null_string(handle)
                        if not filename:
                            break
                        entry_data = handle.read(18)
                        if len(entry_data) != 18:
                            return entries
                        _crc, preload_bytes, archive_index, _entry_offset, entry_size, _term = struct.unpack("<IHHIIH", entry_data)
                        handle.read(preload_bytes)
                        path_name = "" if path in (" ", ".") else path
                        entry_name = f"{path_name}/{filename}.{extension}" if path_name else f"{filename}.{extension}"
                        entries.append({
                            "name": entry_name.replace("\\", "/"),
                            "archive_index": archive_index,
                            "size": preload_bytes + entry_size,
                        })
    except OSError:
        return []
    return entries


def safe_extracted_path(entry_name):
    relative = Path(entry_name.replace("\\", "/"))
    if relative.is_absolute() or ".." in relative.parts:
        return None
    if not relative.parts or relative.parts[0].lower() not in ALLOWED_EXTRACT_ROOTS:
        return None
    target = (GAME_DIR / relative).resolve()
    try:
        target.relative_to(GAME_DIR.resolve())
    except ValueError:
        return None
    return target


def available_maps():
    maps = {path.stem for path in MAPS_DIR.glob("*.bsp")}
    for vpk in ADDONS_DIR.glob("*.vpk"):
        maps.update(vpk_maps(vpk))
    return maps


def current_default_maps():
    maps = set()
    for script in ROOMS.values():
        try:
            text = script.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        match = re.search(r"(?:^|\s)\+map\s+(\S+)", text)
        if match:
            maps.add(match.group(1).lower())
    return maps


def set_default_map(room, map_name):
    if room not in ROOMS:
        fail("unknown room")
    if not MAP_RE.match(map_name):
        fail("invalid map name")
    if map_name not in available_maps():
        fail("map is not installed")

    script = ROOMS[room]
    text = script.read_text(encoding="utf-8", errors="replace")
    updated, count = re.subn(r"(?<=\s)\+map\s+\S+", f"+map {map_name}", text, count=1)
    if count != 1:
        fail("script does not contain one +map parameter")

    backup = script.with_name(f"{script.name}.bak-{time.strftime('%Y%m%d-%H%M%S')}")
    shutil.copy2(script, backup)
    script.write_text(updated, encoding="utf-8")
    print(f"updated {script} to {map_name}; backup {backup}")


def safe_title(value):
    value = value.strip() or "workshop_item"
    value = re.sub(r"[^A-Za-z0-9_.-]+", "_", value)
    value = value.strip("._-")
    return (value or "workshop_item")[:80]


def chown_steam(path):
    subprocess.run(["/usr/bin/chown", "-R", "steam:steam", str(path)], check=False)


def fetch_workshop_details(workshop_id):
    data = urllib.parse.urlencode(
        {"itemcount": "1", "publishedfileids[0]": workshop_id}
    ).encode("utf-8")
    request = urllib.request.Request(
        "https://api.steampowered.com/ISteamRemoteStorage/GetPublishedFileDetails/v1/",
        data=data,
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=30) as response:
        payload = json.loads(response.read().decode("utf-8"))
    details = payload.get("response", {}).get("publishedfiledetails", [{}])[0]
    if str(details.get("result")) != "1":
        fail(f"Steam API returned result {details.get('result', 'unknown')}")
    file_url = details.get("file_url")
    if not file_url or not file_url.startswith(("http://", "https://")):
        fail("Steam API did not return a downloadable file_url")
    return details


def download_file(url, destination, allowed_hosts=None):
    request = urllib.request.Request(url, headers={"User-Agent": "L4D2Manager/0.1"})
    tmp = destination.with_suffix(destination.suffix + ".part")
    with urllib.request.urlopen(request, timeout=60) as response, open(tmp, "wb") as handle:
        final_url = response.geturl()
        if allowed_hosts:
            host = urllib.parse.urlparse(final_url).netloc.lower()
            if host not in allowed_hosts:
                fail(f"download redirected to unsupported host: {host}")
        total = int(response.headers.get("Content-Length") or 0)
        downloaded = 0
        last_emit = 0
        emit("progress", stage="downloading", downloaded=downloaded, total=total, message="Download started")
        while True:
            chunk = response.read(1024 * 1024)
            if not chunk:
                break
            handle.write(chunk)
            downloaded += len(chunk)
            now = time.monotonic()
            if now - last_emit >= 0.5 or (total and downloaded >= total):
                emit(
                    "progress",
                    stage="downloading",
                    downloaded=downloaded,
                    total=total,
                    message="Downloading",
                )
                last_emit = now
    tmp.replace(destination)
    emit("progress", stage="downloaded", downloaded=downloaded, total=total, message="Download finished")


def extract_map_package(destination):
    if not VPK_EXTRACTOR.is_file():
        fail(f"VPK extractor missing: {VPK_EXTRACTOR}")
    emit("stage", stage="extracting", message=f"Extracting {destination.name}")
    result = subprocess.run(
        ["/usr/bin/python3", str(VPK_EXTRACTOR), str(destination), str(GAME_DIR)],
        check=False,
        capture_output=True,
        text=True,
        timeout=600,
    )
    if result.returncode != 0:
        fail(result.stderr or result.stdout or "VPK extraction failed")
    for name in ("maps", "missions", "materials", "models", "sound", "scripts"):
        path = GAME_DIR / name
        if path.exists():
            chown_steam(path)
    emit("stage", stage="extracted", message=f"Extracted {destination.name}")


def install_workshop(kind, workshop_id):
    if kind not in {"map", "mod"}:
        fail("kind must be map or mod")
    if not WORKSHOP_ID_RE.match(workshop_id):
        fail("invalid workshop id")
    ADDONS_DIR.mkdir(parents=True, exist_ok=True)
    DOWNLOAD_DIR.mkdir(parents=True, exist_ok=True)

    details = fetch_workshop_details(workshop_id)
    title = safe_title(details.get("title", "workshop_item"))
    destination = ADDONS_DIR / f"{kind}_{workshop_id}_{title}.vpk"
    download_target = DOWNLOAD_DIR / f"{workshop_id}.vpk"
    emit("stage", stage="preparing", message=f"Downloading {details.get('title', workshop_id)}")
    download_file(details["file_url"], download_target)
    shutil.copy2(download_target, destination)
    chown_steam(destination)

    if kind == "map":
        extract_map_package(destination)

    emit("message", message=f"installed {destination.name}")


def fetch_gamemaps_details(gamemaps_id):
    if not GAMEMAPS_ID_RE.match(gamemaps_id):
        fail("invalid GameMaps id")
    url = f"https://www.gamemaps.com/details/{gamemaps_id}"
    request = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            final_host = urllib.parse.urlparse(response.geturl()).netloc.lower()
            if final_host not in GAMEMAPS_HOSTS:
                fail(f"GameMaps details redirected to unsupported host: {final_host}")
            text = response.read(512 * 1024).decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        fail(f"GameMaps details lookup failed: HTTP {exc.code}")
    except urllib.error.URLError as exc:
        fail(f"GameMaps details lookup failed: {exc}")

    title_match = re.search(r"<h1[^>]*>\s*([^<]+)", text, re.IGNORECASE)
    file_match = re.search(r"([A-Za-z0-9_. -]+\.vpk)", text, re.IGNORECASE)
    links = []
    for match in re.finditer(r'href=["\']([^"\']+)["\']', text, re.IGNORECASE):
        href = match.group(1)
        if "download" not in href.lower() and ".vpk" not in href.lower():
            continue
        absolute = urllib.parse.urljoin(url, href)
        host = urllib.parse.urlparse(absolute).netloc.lower()
        if host in GAMEMAPS_HOSTS:
            links.append(absolute)
    links.append(f"https://www.gamemaps.com/download/{gamemaps_id}")
    return {
        "title": title_match.group(1).strip() if title_match else f"gamemaps_{gamemaps_id}",
        "filename": file_match.group(1).strip() if file_match else f"gamemaps_{gamemaps_id}.vpk",
        "links": list(dict.fromkeys(links)),
    }


def assert_vpk_file(path):
    try:
        with open(path, "rb") as handle:
            data = handle.read(4)
    except OSError:
        fail("downloaded file is missing")
    if data != b"\x34\x12\xaa\x55":
        fail("downloaded file is not a VPK")


def install_gamemaps_map(gamemaps_id):
    if not GAMEMAPS_ID_RE.match(gamemaps_id):
        fail("invalid GameMaps id")
    ADDONS_DIR.mkdir(parents=True, exist_ok=True)
    DOWNLOAD_DIR.mkdir(parents=True, exist_ok=True)
    details = fetch_gamemaps_details(gamemaps_id)
    title = safe_title(details["title"])
    destination = ADDONS_DIR / f"map_gamemaps_{gamemaps_id}_{title}.vpk"
    download_target = DOWNLOAD_DIR / f"gamemaps_{gamemaps_id}.vpk"
    errors = []
    for url in details["links"]:
        try:
            emit("stage", stage="preparing", message=f"Downloading {details['title']} from {url}")
            download_file(url, download_target, allowed_hosts=GAMEMAPS_HOSTS)
            assert_vpk_file(download_target)
            break
        except SystemExit:
            raise
        except Exception as exc:
            errors.append(f"{url}: {exc}")
    else:
        fail("GameMaps download failed: " + " | ".join(errors[-3:]))
    shutil.copy2(download_target, destination)
    chown_steam(destination)
    extract_map_package(destination)
    emit("message", message=f"installed {destination.name}")


def set_addon_state(filename, state):
    if not ADDON_RE.match(filename) or "/" in filename or "\\" in filename:
        fail("invalid addon filename")
    if state not in {"enabled", "disabled"}:
        fail("state must be enabled or disabled")
    ADDONS_DIR.mkdir(parents=True, exist_ok=True)
    DISABLED_ADDONS_DIR.mkdir(parents=True, exist_ok=True)

    source_dir = DISABLED_ADDONS_DIR if state == "enabled" else ADDONS_DIR
    target_dir = ADDONS_DIR if state == "enabled" else DISABLED_ADDONS_DIR
    source = source_dir / filename
    target = target_dir / filename
    if not source.is_file():
        fail(f"addon not found in {source_dir}")
    if target.exists():
        fail(f"target already exists: {target}")
    shutil.move(str(source), str(target))
    chown_steam(target)
    print(f"{filename} {state}")


def find_addon_file(filename):
    for root in (ADDONS_DIR, DISABLED_ADDONS_DIR):
        candidate = root / filename
        if candidate.is_file():
            return candidate
    return None


def other_enabled_entry_names(target_path):
    names = set()
    for vpk in ADDONS_DIR.glob("*.vpk"):
        if vpk.resolve() == target_path.resolve():
            continue
        for entry in vpk_entries(vpk):
            names.add(entry["name"].lower())
    return names


def delete_map_package(filename, mode):
    if not ADDON_RE.match(filename) or "/" in filename or "\\" in filename:
        fail("invalid map package filename")
    if mode not in {"soft", "purge"}:
        fail("delete mode must be soft or purge")
    package = find_addon_file(filename)
    if not package:
        print(f"{filename} already absent")
        return
    maps = vpk_maps(package)
    defaults = current_default_maps()
    if defaults & {name.lower() for name in maps}:
        fail("package contains a current default map")

    entries = vpk_entries(package)
    shared_entries = other_enabled_entry_names(package)
    deleted_loose = 0
    for entry in entries:
        if entry["archive_index"] != INLINE_ARCHIVE:
            continue
        if entry["name"].lower() in shared_entries:
            continue
        target = safe_extracted_path(entry["name"])
        if not target or not target.is_file():
            continue
        try:
            if target.stat().st_size != entry["size"]:
                continue
            target.unlink()
            deleted_loose += 1
        except OSError:
            continue
    package.unlink()
    print(f"{filename} {mode} deleted; removed {deleted_loose} loose files")


def main():
    if len(sys.argv) >= 2 and sys.argv[1] == "set-default-map":
        if len(sys.argv) != 4:
            fail("usage: l4d2-webctl set-default-map <room1|room2> <map>")
        set_default_map(sys.argv[2], sys.argv[3])
        return
    if len(sys.argv) >= 2 and sys.argv[1] == "install-workshop":
        if len(sys.argv) != 4:
            fail("usage: l4d2-webctl install-workshop <map|mod> <workshop_id>")
        install_workshop(sys.argv[2], sys.argv[3])
        return
    if len(sys.argv) >= 2 and sys.argv[1] == "install-gamemaps-map":
        if len(sys.argv) != 3:
            fail("usage: l4d2-webctl install-gamemaps-map <gamemaps_id>")
        install_gamemaps_map(sys.argv[2])
        return
    if len(sys.argv) >= 2 and sys.argv[1] == "set-addon-state":
        if len(sys.argv) != 4:
            fail("usage: l4d2-webctl set-addon-state <filename> <enabled|disabled>")
        set_addon_state(sys.argv[2], sys.argv[3])
        return
    if len(sys.argv) >= 2 and sys.argv[1] == "delete-map-package":
        if len(sys.argv) != 4:
            fail("usage: l4d2-webctl delete-map-package <filename> <soft|purge>")
        delete_map_package(sys.argv[2], sys.argv[3])
        return
    fail("usage: l4d2-webctl <set-default-map|install-workshop|install-gamemaps-map|set-addon-state|delete-map-package> ...")


if __name__ == "__main__":
    main()
